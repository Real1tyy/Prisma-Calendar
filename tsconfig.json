{
	"compilerOptions": {
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES2022",
		"allowJs": true,
		"moduleResolution": "bundler",
		"importHelpers": true,
		"isolatedModules": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"lib": ["DOM", "ES2022"],
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitOverride": true,
		"noPropertyAccessFromIndexSignature": true,
		"exactOptionalPropertyTypes": true,
		"incremental": true,
		"tsBuildInfoFile": ".tsbuildinfo",
		"paths": {
			"@real1ty-obsidian-plugins": ["shared/index.ts"],
			"@real1ty-obsidian-plugins/core": ["../shared/src/core/index.ts"],
			"@real1ty-obsidian-plugins/testing": ["../shared/src/testing/index.ts"],
			"@real1ty-obsidian-plugins/testing/visual": ["../shared/src/testing/visual/index.ts"],
			"@real1ty-obsidian-plugins/*": ["shared/*"]
		}
	},
	"include": ["src/**/*.ts", "tests/**/*.ts"],
	"exclude": ["node_modules"]
}
